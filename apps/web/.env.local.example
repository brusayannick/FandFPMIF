# Copy to `.env.local` and adjust for your dev setup. The web frontend reads
# these at build time (NEXT_PUBLIC_*) and at startup (the rest).

# Browser → backend. The default works when you run `uv run uvicorn …` on the
# host. If you're running everything via `docker compose up`, set this to
# http://localhost:8000 (host) — the api container exposes 8000 to the host.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side fetch base (RSC, route handlers). Inside docker-compose this is
# `http://api:8000`; on the host it's the same as NEXT_PUBLIC_API_URL.
INTERNAL_API_URL=http://localhost:8000
